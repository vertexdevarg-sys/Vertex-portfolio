ck-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">const</span><span> </span><span class="ͼt">projects</span><span> </span><span class="ͼn">=</span><span> [</span><br><span>  {</span><br><span>    title: </span><span class="ͼr">"Hotel Ansenuza • Pedidos &amp; Cocina"</span><span>,</span><br><span>    desc: </span><span class="ͼr">"Sistema de pedidos con tickets para cocina, control por mesas y estados."</span><span>,</span><br><span>    tags: [</span><span class="ͼr">"PHP"</span><span>, </span><span class="ͼr">"MySQL"</span><span>, </span><span class="ͼr">"Tickets"</span><span>]</span><br><span>  },</span><br><span>  {</span><br><span>    title: </span><span class="ͼr">"Hattrick • E-commerce"</span><span>,</span><br><span>    desc: </span><span class="ͼr">"Catálogo, PDP, carrito y checkout por WhatsApp con diseño mobile-first."</span><span>,</span><br><span>    tags: [</span><span class="ͼr">"HTML"</span><span>, </span><span class="ͼr">"CSS"</span><span>, </span><span class="ͼr">"JS"</span><span>]</span><br><span>  },</span><br><span>  {</span><br><span>    title: </span><span class="ͼr">"Kiosco POS • Offline"</span><span>,</span><br><span>    desc: </span><span class="ͼr">"Ventas rápidas, lector de código, tickets y stock local."</span><span>,</span><br><span>    tags: [</span><span class="ͼr">"JS"</span><span>, </span><span class="ͼr">"Offline"</span><span>, </span><span class="ͼr">"Impresión"</span><span>]</span><br><span>  }</span><br><span>];</span><br><br><span class="ͼn">const</span><span> </span><span class="ͼt">$</span><span> </span><span class="ͼn">=</span><span> (</span><span class="ͼt">q</span><span>, </span><span class="ͼt">el</span><span class="ͼn">=</span><span class="ͼt">document</span><span>) =&gt; </span><span class="ͼt">el</span><span class="ͼn">.</span><span>querySelector(</span><span class="ͼt">q</span><span>);</span><br><br><span class="ͼn">function</span><span> </span><span class="ͼt">renderProjects</span><span>(){</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">grid</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">$</span><span>(</span><span class="ͼr">"#projectsGrid"</span><span>);</span><br><span>  </span><span class="ͼt">grid</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼt">projects</span><span class="ͼn">.</span><span>map(</span><span class="ͼt">p</span><span> =&gt; </span><span class="ͼr">`</span><br><span class="ͼr">    &lt;article class="project"&gt;</span><br><span class="ͼr">      &lt;h3&gt;</span><span>${</span><span class="ͼt">p</span><span class="ͼn">.</span><span>title}</span><span class="ͼr">&lt;/h3&gt;</span><br><span class="ͼr">      &lt;p&gt;</span><span>${</span><span class="ͼt">p</span><span class="ͼn">.</span><span>desc}</span><span class="ͼr">&lt;/p&gt;</span><br><span class="ͼr">      &lt;div class="tags"&gt;</span><br><span class="ͼr">        </span><span>${</span><span class="ͼt">p</span><span class="ͼn">.</span><span>tags</span><span class="ͼn">.</span><span>map(</span><span class="ͼt">t</span><span> =&gt; </span><span class="ͼr">`&lt;span class="tag"&gt;</span><span>${</span><span class="ͼt">t</span><span>}</span><span class="ͼr">&lt;/span&gt;`</span><span>)</span><span class="ͼn">.</span><span>join(</span><span class="ͼr">""</span><span>)}</span><br><span class="ͼr">      &lt;/div&gt;</span><br><span class="ͼr">    &lt;/article&gt;</span><br><span class="ͼr">  `</span><span>)</span><span class="ͼn">.</span><span>join(</span><span class="ͼr">""</span><span>);</span><br><span>}</span><br><br><span class="ͼn">function</span><span> </span><span class="ͼt">mobileMenu</span><span>(){</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">btn</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">$</span><span>(</span><span class="ͼr">"#menuBtn"</span><span>);</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">nav</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">$</span><span>(</span><span class="ͼr">"#nav"</span><span>);</span><br><span>  </span><span class="ͼt">btn</span><span class="ͼn">.</span><span>addEventListener(</span><span class="ͼr">"click"</span><span>, () =&gt; </span><span class="ͼt">nav</span><span class="ͼn">.</span><span>classList</span><span class="ͼn">.</span><span>toggle(</span><span class="ͼr">"open"</span><span>));</span><br><span>  </span><span class="ͼt">window</span><span class="ͼn">.</span><span>addEventListener(</span><span class="ͼr">"click"</span><span>, (</span><span class="ͼt">e</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">if</span><span>(</span><span class="ͼn">!</span><span class="ͼt">nav</span><span class="ͼn">.</span><span>contains(</span><span class="ͼt">e</span><span class="ͼn">.</span><span>target) </span><span class="ͼn">&amp;&amp;</span><span> </span><span class="ͼn">!</span><span class="ͼt">btn</span><span class="ͼn">.</span><span>contains(</span><span class="ͼt">e</span><span class="ͼn">.</span><span>target)) </span><span class="ͼt">nav</span><span class="ͼn">.</span><span>classList</span><span class="ͼn">.</span><span>remove(</span><span class="ͼr">"open"</span><span>);</span><br><span>  });</span><br><span>}</span><br><br><span class="ͼn">function</span><span> </span><span class="ͼt">contactToWhatsapp</span><span>(){</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">form</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">$</span><span>(</span><span class="ͼr">"#contactForm"</span><span>);</span><br><span>  </span><span class="ͼt">form</span><span class="ͼn">.</span><span>addEventListener(</span><span class="ͼr">"submit"</span><span>, (</span><span class="ͼt">e</span><span>) =&gt; {</span><br><span>    </span><span class="ͼt">e</span><span class="ͼn">.</span><span>preventDefault();</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">fd</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">new</span><span> </span><span class="ͼt">FormData</span><span>(</span><span class="ͼt">form</span><span>);</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">name</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">fd</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"name"</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">""</span><span>;</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">phone</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">fd</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"phone"</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">""</span><span>;</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">need</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">fd</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"need"</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">""</span><span>;</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">msg</span><span>  </span><span class="ͼn">=</span><span> </span><span class="ͼt">fd</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"msg"</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">""</span><span>;</span><br><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">text</span><span> </span><span class="ͼn">=</span><br><span class="ͼr">`Hola! Soy </span><span>${</span><span class="ͼt">name</span><span>}</span><span class="ͼr">.</span><br><span class="ͼr">Mi WhatsApp: </span><span>${</span><span class="ͼt">phone</span><span>}</span><br><span class="ͼr">Necesito: </span><span>${</span><span class="ͼt">need</span><span>}</span><br><span class="ͼr">Detalles: </span><span>${</span><span class="ͼt">msg</span><span>}</span><span class="ͼr">`</span><span class="ͼn">.</span><span>trim();</span><br><br><span>    </span><span class="ͼl">// PONÉ TU NÚMERO con código país (Argentina: 54 + número)</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">yourNumber</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">"5493560000000"</span><span>; </span><span class="ͼl">// &lt;-- CAMBIAR</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">url</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">`https://wa.me/</span><span>${</span><span class="ͼt">yourNumber</span><span>}</span><span class="ͼr">?text=</span><span>${</span><span class="ͼt">encodeURIComponent</span><span>(</span><span class="ͼt">text</span><span>)}</span><span class="ͼr">`</span><span>;</span><br><span>    </span><span class="ͼt">window</span><span class="ͼn">.</span><span>open(</span><span class="ͼt">url</span><span>, </span><span class="ͼr">"_blank"</span><span>);</span><br><span>  });</span><br><span>}</span><br><br><span class="ͼn">function</span><span> </span><span class="ͼt">setYear</span><span>(){</span><br><span>  </span><span class="ͼt">$</span><span>(</span><span class="ͼr">"#year"</span><span>)</span><span class="ͼn">.</span><span>textContent </span><span class="ͼn">=</span><span> </span><span class="ͼn">new</span><span> </span><span class="ͼt">Date</span><span>()</span><span class="ͼn">.</span><span>getFullYear();</span><br><span>}</span><br><br><span class="ͼt">renderProjects</span><span>();</span><br><span class="ͼt">mobileMenu</span><span>();</span><br><span class="ͼt">contactToWhatsapp</span><span>();</span><br><span class="ͼt">setYear</span><span>();</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="18253" data-end="18256">
<h1 data-start="18258" data-end="18322">✅ Listo. Eso YA es un portfolio tipo ese, pero en HTML/CSS/JS.</h1>
<p data-start="18324" data-end="18427">Ahora, para dejarlo <strong data-start="18344" data-end="18359">clavadísimo</strong> al repo que estás viendo, necesito 1 cosa y lo hacemos sin vueltas:</p>
<p data-start="18429" data-end="18474">📌 Decime <strong data-start="18439" data-end="18473">qué parte querés copiar exacta</strong>:</p>
<ol data-start="18475" data-end="18669">
<li data-start="18475" data-end="18530">
<p data-start="18478" data-end="18530"><strong data-start="18478" data-end="18486">Hero</strong> (tipografía, botones, fondo, animaciones)</p>
</li>
<li data-start="18531" data-end="18591">
<p data-start="18534" data-end="18591"><strong data-start="18534" data-end="18562">Sección “RecentProjects”</strong> (cards con hover + imagen)</p>
</li>
<li data-start="18592" data-end="18622">
<p data-start="18595" data-end="18622"><strong data-start="18595" data-end="18609">Experience</strong> (timeline)</p>
</li>
<li data-start="18623" data-end="18669">
<p data-start="18626" data-end="18669"><strong data-start="18626" data-end="18637">Clients</strong> (marquesina / logos animados)</p>
</li>
</ol>
<p data-start="18671" data-end="18735" data-is-last-node="" data-is-only-node="">Decime “copiemos la 2 y la 3” y te lo dejo igualito en estático.</p></div></div></div></div><div class="z-0 flex min-h-[46px] justify-start"><div class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none touch:w-[calc(100%+--spacing(3.5))] -mt-1 w-[calc(100%+--spacing(2.5))] duration-[1.5s] focus-within:transition-none hover:transition-none touch:pointer-events-auto pointer-events-none [mask-image:linear-gradient(to_right,black_33%,transparent_66%)] [mask-size:300%_100%] [mask-position:100%_0%] motion-safe:transition-[mask-position] group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:[mask-position:0_0] group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:[mask-position:0_0] has-data-[state=open]:pointer-events-auto has-data-[state=open]:[mask-position:0_0]" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copiar" aria-pressed="false" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-m5oiq452.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Respuesta adecuada" aria-pressed="false" data-testid="good-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-m5oiq452.svg#51753c" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Respuesta inadecuada